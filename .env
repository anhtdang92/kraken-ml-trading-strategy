# GCP Configuration
GOOGLE_CLOUD_PROJECT=crypto-ml-trading-487
GCP_REGION=us-central1
BIGQUERY_DATASET=crypto_data
STORAGE_BUCKET_MODELS=crypto-ml-models-crypto-ml-trading-487-models
STORAGE_BUCKET_TRAINING=crypto-ml-models-crypto-ml-trading-487-training-data

# Vertex AI (will be updated after endpoint creation)
VERTEX_ENDPOINT_ID=

# Service Account Keys
GOOGLE_APPLICATION_CREDENTIALS=config/keys/crypto-app-sa-key.json
ML_TRAINING_SA_KEY=config/keys/ml-training-sa-key.json
ML_PREDICTION_SA_KEY=config/keys/ml-prediction-sa-key.json

# Cost Optimization Settings
USE_PREEMPTIBLE_INSTANCES=true
AUTO_SCALE_ENDPOINT=true
MIN_REPLICA_COUNT=0
MAX_REPLICA_COUNT=3
